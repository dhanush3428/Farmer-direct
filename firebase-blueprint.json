{
  "entities": {
    "FarmerProfile": {
      "title": "FarmerProfile",
      "description": "Information about a registered farmer and their outlet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "farmName": { "type": "string" },
        "description": { "type": "string" },
        "photo": { "type": "string" },
        "pin": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "village": { "type": "string" },
        "district": { "type": "string" },
        "state": { "type": "string" },
        "createdAt": { "type": "string" },
        "contact": { "type": "string" },
        "location": { "type": "string" },
        "selectedCrops": { "type": "array" }
      },
      "required": ["id", "name", "farmName", "pin"]
    },
    "BuyerProfile": {
      "title": "BuyerProfile",
      "description": "Information about a buyer profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pin": { "type": "string" },
        "email": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "contact": { "type": "string" },
        "createdAt": { "type": "string" },
        "billingDetails": { "type": "string" },
        "preferredPickupTime": { "type": "string" },
        "preferredPickupLocation": { "type": "string" }
      },
      "required": ["id", "name", "pin"]
    },
    "CropProduct": {
      "title": "CropProduct",
      "description": "Available stock listing created by farmers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "farmName": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Live", "Sold Out"] },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "quantity": { "type": "number" },
        "harvestDate": { "type": "string" }
      },
      "required": ["id", "farmerId", "name", "category", "price", "stock", "unit", "status"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "Item details within a specific order",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "farmerId": { "type": "string" },
        "farmName": { "type": "string" }
      },
      "required": ["productId", "productName", "quantity", "price", "unit", "farmerId"]
    },
    "Order": {
      "title": "Order",
      "description": "A booking or order details placed by a buyer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "pickupTime": { "type": "string" },
        "feedbackText": { "type": "string" },
        "rating": { "type": "number" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "buyerContact": { "type": "string" },
        "consumerId": { "type": "string" },
        "consumerName": { "type": "string" },
        "consumerContact": { "type": "string" }
      },
      "required": ["id", "date", "items", "total", "status"]
    },
    "FarmerFeedback": {
      "title": "FarmerFeedback",
      "description": "Review and rating left by buyers for farm crops",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "farmerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string" },
        "cropName": { "type": "string" },
        "buyerName": { "type": "string" },
        "consumerName": { "type": "string" }
      },
      "required": ["id", "farmerId", "rating", "comment", "date", "cropName"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "App notification received by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "message", "date", "read"]
    }
  },
  "firestore": {
    "farmers": {
      "schema": "FarmerProfile",
      "description": "Contains direct credentials and farm profiles of farmers"
    },
    "buyers": {
      "schema": "BuyerProfile",
      "description": "Contains demographics and security data of buyers"
    },
    "crops": {
      "schema": "CropProduct",
      "description": "All available farm goods categorized for direct trade"
    },
    "orders": {
      "schema": "Order",
      "description": "Historic and active checkout logs with buyer information"
    },
    "feedbacks": {
      "schema": "FarmerFeedback",
      "description": "Crop reviews compiled for analytics"
    },
    "notifications": {
      "schema": "AppNotification",
      "description": "Reactive notification triggers for active accounts"
    }
  }
}
